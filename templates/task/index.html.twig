{% extends 'base.html.twig' %}

{% block body %}
<div class="container mt-5">
    <h2>Gestion des tâches</h2>

    <a href="{{ path('task_new') }}" class="btn btn-primary mb-3">Ajouter une tâche</a>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Titre</th>
                <th>Description</th>
                <th>Statut</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for task in tasks %}
            <tr>
                <td>{{ task.title }}</td>
                <td>{{ task.description }}</td>
                <td>{{ task.status.value }}</td>
                <td>
                    {% if task.status.value != 'Terminé' %}
                        <a href="{{ path('task_done', {id: task.id}) }}" class="btn btn-success btn-sm">
                            Terminer
                        </a>
                    {% endif %}

                    <form method="post"
                          action="{{ path('task_delete', {id: task.id}) }}"
                          style="display:inline;">
                        <input type="hidden"
                               name="_token"
                               value="{{ csrf_token('delete' ~ task.id) }}">
                        <button class="btn btn-danger btn-sm">
                            Supprimer
                        </button>
                    </form>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">Aucune tâche trouvée</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}